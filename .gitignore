# Dossiers système d'Obsidian
.obsidian/
.obsidian-plugins/
.obsidian-themes/

# Fichiers temporaires et caches
.obsidian/workspace-state.json
.obsidian/graph.json
.obsidian/app.json
.obsidian/preferences.json
.obsidian/state.json
.obsidian/flags.json

# Dossiers de plugins (sauf si tu veux les versionner)
