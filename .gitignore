/**.obsidian/plugins/

# Fichiers de cache
*.cache
*.tmp
*.swp

# Fichiers de verrouillage (pour éviter les conflits)
*.lock

# ==========
# Système
# ==========
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


